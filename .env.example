# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=CLINICORE
APP_ENV=development                    # development | staging | production
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://clinicore:password@localhost:5432/clinicore_db
SYNC_DATABASE_URL=postgresql://clinicore:password@localhost:5432/clinicore_db

# pgcrypto encryption key (used for AES-256 column-level encryption)
DB_ENCRYPTION_KEY=your-32-byte-encryption-key-here!!

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Auth0 ───────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_API_AUDIENCE=https://clinicore-api
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
# Step-up auth action (configured in Auth0 Actions dashboard)
AUTH0_STEPUP_CLIENT_ID=your-stepup-client-id

# ─── AI / LLM ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_AI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=sk-your-openai-key        # optional fallback

# Primary model selection: claude | gemini | openai
PRIMARY_LLM=claude
CLAUDE_MODEL=claude-opus-4-20250514
GEMINI_MODEL=gemini-1.5-pro

# ─── Qdrant Vector DB ────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_PUBMED=pubmed_abstracts
QDRANT_COLLECTION_CASES=clinical_cases

# ─── Embedding Model ─────────────────────────────────────────────────────────
# Options: "pritamdeka/BioLORD-2023" | "neuml/pubmedbert-base-embeddings"
EMBEDDING_MODEL=pritamdeka/BioLORD-2023
EMBEDDING_DIMENSION=768

# ─── MinIO (S3-compatible image/file storage) ─────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_IMAGES=clinicore-images
MINIO_SECURE=false                      # true in production (HTTPS)

# ─── PubMed / NCBI ───────────────────────────────────────────────────────────
NCBI_API_KEY=your-ncbi-api-key          # free at: https://www.ncbi.nlm.nih.gov/account/
NCBI_EMAIL=your-email@domain.com        # required by NCBI
PUBMED_MAX_RESULTS=10
KNOWLEDGE_UPDATE_INTERVAL_HOURS=24

# ─── Email (for sharing notifications) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@clinicore.ai

# ─── Audit & Compliance ──────────────────────────────────────────────────────
AUDIT_LOG_RETENTION_DAYS=2555          # 7 years (HIPAA requirement)
ZERO_RETENTION_TTL_SECONDS=3600        # 1 hour session for zero-retention mode
